{
  "name": "clawmart",
  "version": 1,
  "builds": [
    {
      "src": "clawmart_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "clawmart_server.py" },
    { "src": "/(.*)", "dest": "clawmart_server.py" }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
